# ── LLM Configuration ────────────────────────────────────────────────────────
# Provider: gemini (FREE) | groq (FREE) | anthropic | openai
LLM_PROVIDER=gemini

# API key for your chosen LLM provider
# Gemini (FREE): https://aistudio.google.com → Get API Key
# Groq   (FREE): https://console.groq.com → API Keys
LLM_API_KEY=your_api_key_here

# Model name per provider:
# Gemini:    gemini-1.5-flash        ← recommended free option
# Groq:      llama-3.1-8b-instant    ← recommended free option
# Anthropic: claude-sonnet-4-20250514
# OpenAI:    gpt-4o-mini
LLM_MODEL=gemini-1.5-flash

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./peblo.db

# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/peblo

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Adaptive Difficulty ───────────────────────────────────────────────────────
# Promote difficulty after N consecutive correct answers
CORRECT_STREAK_TO_INCREASE=3
# Demote difficulty after N consecutive wrong answers
INCORRECT_STREAK_TO_DECREASE=2
